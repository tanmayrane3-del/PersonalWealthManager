<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <queries>
        <package android:name="com.google.android.gms" />
    </queries>

    <application
        android:name=".FinanceTrackerApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PersonalWealthManager"
        tools:targetApi="31">

        <!-- Login Activity (Launcher) -->
        <activity
            android:name=".presentation.auth.login.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.PersonalWealthManager">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Register Activity -->
        <activity
            android:name=".presentation.auth.register.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <!-- Main Activity (Dashboard) -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <!-- Transactions Activity -->
        <activity
            android:name=".presentation.transactions.TransactionsActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <!-- Edit Transaction Activity (Add/Edit) -->
        <activity
            android:name=".presentation.transactions.EditTransactionActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager"
            android:windowSoftInputMode="adjustResize" />

        <!-- Category Management Activity -->
        <activity
            android:name=".presentation.categories.CategoryManagementActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <!-- Source Management Activity -->
        <activity
            android:name=".presentation.sources.SourceManagementActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <!-- Recipient Management Activity -->
        <activity
            android:name=".presentation.recipients.RecipientManagementActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <!-- Stocks Activity — singleTop so onNewIntent fires after Chrome Custom Tab redirect -->
        <activity
            android:name=".presentation.stocks.StocksActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.PersonalWealthManager">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="wealthapp" android:host="auth" android:path="/callback" />
            </intent-filter>
        </activity>

        <!-- Metals Activity -->
        <activity
            android:name=".presentation.metals.MetalsActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <!-- Mutual Funds Activity -->
        <activity
            android:name=".presentation.mutualfunds.MutualFundsActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <!-- Other Assets Activities -->
        <activity
            android:name=".presentation.otherassets.OtherAssetsActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <activity
            android:name=".presentation.otherassets.AddEditOtherAssetActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <!-- Liabilities Activities -->
        <activity
            android:name=".presentation.liabilities.LiabilitiesActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <!-- Net Worth Activity -->
        <activity
            android:name=".presentation.networth.NetWorthActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <activity
            android:name=".presentation.liabilities.AddEditLiabilityActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <!-- CAS Import Activity -->
        <activity
            android:name=".presentation.mutualfunds.CasImportActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <!-- Setup Zerodha Activity -->
        <activity
            android:name=".presentation.zerodha.SetupZerodhaActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager"
            android:windowSoftInputMode="adjustResize" />

        <!-- Settings -->
        <activity
            android:name=".presentation.settings.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <activity
            android:name=".presentation.settings.SmsLogActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalWealthManager" />

        <!-- SMS BroadcastReceiver for auto expense creation -->
        <receiver
            android:name=".core.sms.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="1000">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- Disable WorkManager's default initializer — we use HiltWorkerFactory instead -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
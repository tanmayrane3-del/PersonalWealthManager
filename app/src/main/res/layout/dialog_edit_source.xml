<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="36dp">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="28dp"
            android:background="@drawable/bs_drag_handle" />

        <!-- Hidden close button (retained for Activity compatibility) -->
        <ImageView
            android:id="@+id/btnCloseDialog"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- Icon circle -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bs_icon_circle">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_account_balance"
                app:tint="@color/teal_800" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/add_source"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:gravity="center"
            android:fontFamily="sans-serif-medium" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Automate tracking by linking a specific identifier or bank account."
            android:textSize="13sp"
            android:textColor="@color/drawer_item_text"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="28dp" />

        <!-- Source Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SOURCE NAME"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/drawer_item_subtext"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bs_field_bg">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSourceName"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:hint="e.g. Personal Savings"
                android:inputType="textCapWords"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />
        </FrameLayout>

        <!-- Description (Optional) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DESCRIPTION"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/drawer_item_subtext"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Optional"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bs_field_bg">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSourceDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:background="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:gravity="top|start"
                android:hint="Main account for daily expenses"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />
        </FrameLayout>

        <!-- Source Identifier -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SOURCE IDENTIFIER"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/drawer_item_subtext"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bs_field_bg">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSourceIdentifier"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:paddingStart="16dp"
                android:paddingEnd="48dp"
                android:gravity="center_vertical"
                android:hint="company@upi or EMPLOYER"
                android:inputType="text"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="14dp"
                android:src="@android:drawable/ic_dialog_info"
                android:alpha="0.4"
                android:contentDescription="Used for SMS/Transaction matching" />
        </FrameLayout>

        <!-- Default Category -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DEFAULT CATEGORY"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/drawer_item_subtext"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bs_field_bg">

            <Spinner
                android:id="@+id/spinnerDefaultCategory"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:paddingStart="16dp"
                android:paddingEnd="40dp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="14dp"
                android:src="@drawable/ic_expand_more"
                app:tint="@color/drawer_item_text"
                android:contentDescription="@null"
                android:clickable="false"
                android:focusable="false" />
        </FrameLayout>

        <!-- Transaction warning -->
        <TextView
            android:id="@+id/tvTransactionWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/warning_orange"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingTop="12dp"
            android:visibility="gone" />

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:indeterminateTint="@color/teal_700"
            android:visibility="gone" />

        <!-- Error message -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/error_red"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingTop="8dp"
            android:visibility="gone" />

        <!-- Action Buttons -->
        <LinearLayout
            android:id="@+id/buttonsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Cancel"
                android:textColor="@color/teal_800"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginEnd="8dp"
                app:strokeColor="@color/teal_800"
                app:strokeWidth="1.5dp"
                app:cornerRadius="28dp"
                app:backgroundTint="@android:color/transparent"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="@string/save"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginStart="8dp"
                app:backgroundTint="@color/teal_800"
                app:cornerRadius="28dp"
                app:elevation="0dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />
        </LinearLayout>

        <!-- Delete Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/delete_source"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="15sp"
            android:visibility="gone"
            app:backgroundTint="@color/error_red"
            app:cornerRadius="28dp"
            app:elevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>

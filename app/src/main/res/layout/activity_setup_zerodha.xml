<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main Content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:background="@drawable/gradient_background">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:paddingTop="24dp">

                <!-- App Bar Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="32dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/connect_zerodha"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/btnMenu"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_menu"
                        android:contentDescription="@string/menu" />
                </LinearLayout>

                <!-- API Key -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/api_key_hint"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="@string/api_key_hint"
                    android:textColor="@android:color/white"
                    android:textColorHint="#80FFFFFF"
                    android:background="@drawable/edit_text_background"
                    android:paddingHorizontal="14dp"
                    android:inputType="text"
                    android:layout_marginBottom="20dp" />

                <!-- API Secret -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/api_secret_hint"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etApiSecret"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="@string/api_secret_hint"
                    android:textColor="@android:color/white"
                    android:textColorHint="#80FFFFFF"
                    android:background="@drawable/edit_text_background"
                    android:paddingHorizontal="14dp"
                    android:inputType="textPassword"
                    android:layout_marginBottom="28dp" />

                <!-- Save Button -->
                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="@string/save_credentials"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@color/card_dark_teal"
                    android:layout_marginBottom="16dp" />

                <!-- Check Holdings Button (hidden until credentials saved) -->
                <Button
                    android:id="@+id/btnCheckHoldings"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="@string/check_holdings"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@color/card_dark_teal"
                    android:visibility="gone"
                    android:layout_marginBottom="32dp" />

                <!-- Info Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_dark_teal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/zerodha_steps_title"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/zerodha_steps"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginBottom="14dp" />

                        <Button
                            android:id="@+id/btnOpenKiteApps"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/open_kite_apps"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:background="@color/card_medium_teal" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/card_medium_teal"
        app:headerLayout="@layout/drawer_header" />

</androidx.drawerlayout.widget.DrawerLayout>

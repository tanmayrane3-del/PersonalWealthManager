<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gradient_start">

    <!-- Main Content Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- App Bar (dark teal) -->
            <LinearLayout
                android:id="@+id/appBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical"
                android:background="@color/teal_800"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_back"
                    android:contentDescription="@string/back_button"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/category_management"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp" />

                <ImageView
                    android:id="@+id/btnMenu"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_menu"
                    android:contentDescription="@string/menu"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Search Bar (same dark teal band) -->
            <LinearLayout
                android:id="@+id/searchContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/teal_800"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp"
                app:layout_constraintTop_toBottomOf="@id/appBar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/search_bar_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search"
                        android:contentDescription="@null"
                        android:layout_marginEnd="10dp" />

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Search categories..."
                        android:textColor="@android:color/white"
                        android:textColorHint="#99FFFFFF"
                        android:textSize="15sp"
                        android:inputType="text"
                        android:imeOptions="actionSearch"
                        android:singleLine="true" />

                </LinearLayout>

            </LinearLayout>

            <!-- Scrollable Content (white background) -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:fillViewport="true"
                app:layout_constraintTop_toBottomOf="@id/searchContainer"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@android:color/white"
                    android:paddingTop="8dp"
                    android:paddingBottom="80dp">

                    <!-- ── Income Section ── -->

                    <LinearLayout
                        android:id="@+id/incomeHeader"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:layout_marginTop="8dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/income_categories"
                            android:textColor="@color/text_dark"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvIncomeCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 TOTAL"
                            android:textColor="@color/teal_800"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/badge_count_bg" />

                        <ImageView
                            android:id="@+id/ivIncomeExpand"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_expand_less"
                            app:tint="@color/text_muted"
                            android:contentDescription="@string/expand_collapse" />

                    </LinearLayout>

                    <!-- Income collapsible content -->
                    <LinearLayout
                        android:id="@+id/incomeContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Global income categories -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvIncomeGlobalCategories"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                        <!-- Divider before custom categories -->
                        <View
                            android:id="@+id/incomeDivider"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"
                            android:background="@color/gray_200"
                            android:visibility="gone" />

                        <!-- "CUSTOM" sub-label -->
                        <TextView
                            android:id="@+id/tvIncomeCustomLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="CUSTOM"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:paddingStart="16dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="4dp"
                            android:visibility="gone" />

                        <!-- User income categories -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvIncomeUserCategories"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                        <TextView
                            android:id="@+id/tvNoIncomeUserCategories"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/no_categories"
                            android:textColor="@color/text_muted"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:visibility="gone" />

                    </LinearLayout>

                    <!-- Divider between Income and Expense sections -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="@color/gray_200" />

                    <!-- ── Expense Section ── -->

                    <LinearLayout
                        android:id="@+id/expenseHeader"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/expense_categories"
                            android:textColor="@color/text_dark"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvExpenseCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 TOTAL"
                            android:textColor="@color/teal_800"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/badge_count_bg" />

                        <ImageView
                            android:id="@+id/ivExpenseExpand"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_expand_less"
                            app:tint="@color/text_muted"
                            android:contentDescription="@string/expand_collapse" />

                    </LinearLayout>

                    <!-- Expense collapsible content -->
                    <LinearLayout
                        android:id="@+id/expenseContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Global expense categories -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvExpenseGlobalCategories"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                        <!-- Divider before custom categories -->
                        <View
                            android:id="@+id/expenseDivider"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"
                            android:background="@color/gray_200"
                            android:visibility="gone" />

                        <!-- "CUSTOM" sub-label -->
                        <TextView
                            android:id="@+id/tvExpenseCustomLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="CUSTOM"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:paddingStart="16dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="4dp"
                            android:visibility="gone" />

                        <!-- User expense categories -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvExpenseUserCategories"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                        <TextView
                            android:id="@+id/tvNoExpenseUserCategories"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/no_categories"
                            android:textColor="@color/text_muted"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

            </ScrollView>

            <!-- Loading State -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- FAB — sits above the bottom nav bar -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAddCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="82dp"
                android:src="@drawable/ic_add"
                android:contentDescription="Add Category"
                app:backgroundTint="@color/teal_800"
                app:tint="@android:color/white"
                app:elevation="8dp"
                app:pressedTranslationZ="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <include
            layout="@layout/layout_bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom" />

    </FrameLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/drawer_bg"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/drawer_header" />

</androidx.drawerlayout.widget.DrawerLayout>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/card_medium_teal"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Time Filter -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_time"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Date From -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/date_from"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etDateFrom"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/card_bg"
            android:padding="12dp"
            android:textColor="@android:color/white"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginBottom="12dp" />

        <!-- Date To -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/date_to"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etDateTo"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/card_bg"
            android:padding="12dp"
            android:textColor="@android:color/white"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginBottom="24dp" />

        <!-- Type Filter -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_type"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Transaction Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/income_expense"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerType"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Category -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/category"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Source -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/source"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerSource"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Recipient -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recipient"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerRecipient"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="24dp" />

        <!-- Amount Filter -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_amount"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Min Amount -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/min_amount"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etMinAmount"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/card_bg"
            android:padding="12dp"
            android:textColor="@android:color/white"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp" />

        <!-- Max Amount -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/max_amount"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etMaxAmount"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/card_bg"
            android:padding="12dp"
            android:textColor="@android:color/white"
            android:inputType="numberDecimal"
            android:layout_marginBottom="24dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btnResetFilters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reset_filters"
                android:textColor="@android:color/white"
                android:background="@color/card_bg"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnApplyFilters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/apply_filters"
                android:textColor="@color/text_dark"
                android:background="@color/card_light_teal" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
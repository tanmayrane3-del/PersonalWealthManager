<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/card_medium_teal">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Top-left: Qty & Avg -->
        <TextView
            android:id="@+id/tvQtyAvg"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tvPnlPercent"
            android:text="Qty. 10 • Avg. 1,500.00" />

        <!-- Top-right: P&L % -->
        <TextView
            android:id="@+id/tvPnlPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="+6.67%" />

        <!-- Middle-left: Stock symbol -->
        <TextView
            android:id="@+id/tvSymbol"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvQtyAvg"
            app:layout_constraintEnd_toStartOf="@+id/tvPnlAmount"
            android:text="INFY" />

        <!-- Middle-right: P&L amount -->
        <TextView
            android:id="@+id/tvPnlAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvPnlPercent"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="+₹1,000.00" />

        <!-- Bottom-left: Invested -->
        <TextView
            android:id="@+id/tvInvested"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="6dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSymbol"
            app:layout_constraintEnd_toStartOf="@+id/tvLtp"
            android:text="Invested 15,000.00" />

        <!-- Bottom-right: LTP + day change -->
        <TextView
            android:id="@+id/tvLtp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvPnlAmount"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="LTP 1,600.00 (+10.00)" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>

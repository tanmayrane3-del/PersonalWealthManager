<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/metals_bg">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="16dp">

                <!-- ── Live Gold Rates ─────────────────────────────── -->

                <!-- Section header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Live Gold Rates"
                        android:textColor="@color/metals_label_muted"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvLastUpdated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Updated: --"
                        android:textColor="@color/metals_label_muted"
                        android:textSize="11sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:background="@drawable/bg_metals_rate_updated" />

                </LinearLayout>

                <!-- 2-column rate cards -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="16dp">

                    <!-- Gold 22K -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GOLD 22K"
                                android:textColor="@color/metals_label_muted"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvRate22k"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹--"
                                android:textColor="@color/teal_800"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="per gram"
                                android:textColor="@color/metals_label_muted"
                                android:textSize="10sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Gold 24K -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GOLD 24K"
                                android:textColor="@color/metals_label_muted"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvRate24k"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹--"
                                android:textColor="@color/teal_800"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="per gram"
                                android:textColor="@color/metals_label_muted"
                                android:textSize="10sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ── Portfolio Summary Card ──────────────────────── -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/card_dark_teal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Header: label + value + refresh button -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="top">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Metals Value"
                                    android:textColor="#CCFFFFFF"
                                    android:textSize="13sp"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/tvTotalValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹0"
                                    android:textColor="@color/white"
                                    android:textSize="32sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <ImageView
                                android:id="@+id/ivSyncCagr"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:padding="8dp"
                                android:src="@drawable/ic_refresh"
                                android:tint="@color/white"
                                android:contentDescription="Sync CAGR"
                                android:background="@drawable/bg_metals_refresh_btn"
                                android:clickable="true"
                                android:focusable="true" />

                        </LinearLayout>

                        <!-- CAGR Projections (hidden until available) -->
                        <LinearLayout
                            android:id="@+id/cagrProjectionsSection"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            android:layout_marginTop="16dp">

                            <!-- Divider -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#1AFFFFFF"
                                android:layout_marginBottom="12dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CAGR PROJECTIONS"
                                android:textColor="#99FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08"
                                android:layout_marginBottom="10dp" />

                            <!-- 3-column grid -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <!-- 1Y -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="1Y"
                                        android:textColor="#80FFFFFF"
                                        android:textSize="10sp"
                                        android:layout_marginBottom="2dp" />

                                    <TextView
                                        android:id="@+id/tvCagrValue1y"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="--"
                                        android:textColor="@color/white"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:layout_marginBottom="4dp" />

                                    <TextView
                                        android:id="@+id/tvCagrPct1y"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="--%"
                                        android:textColor="@color/metals_cagr_badge_text"
                                        android:textSize="10sp"
                                        android:textStyle="bold"
                                        android:paddingStart="6dp"
                                        android:paddingEnd="6dp"
                                        android:paddingTop="2dp"
                                        android:paddingBottom="2dp"
                                        android:background="@drawable/bg_cagr_pct_badge" />

                                </LinearLayout>

                                <!-- Vertical divider -->
                                <View
                                    android:layout_width="1dp"
                                    android:layout_height="match_parent"
                                    android:background="#1AFFFFFF"
                                    android:layout_marginEnd="0dp" />

                                <!-- 3Y -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="3Y"
                                        android:textColor="#80FFFFFF"
                                        android:textSize="10sp"
                                        android:layout_marginBottom="2dp" />

                                    <TextView
                                        android:id="@+id/tvCagrValue3y"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="--"
                                        android:textColor="@color/white"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:layout_marginBottom="4dp" />

                                    <TextView
                                        android:id="@+id/tvCagrPct3y"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="--%"
                                        android:textColor="@color/metals_cagr_badge_text"
                                        android:textSize="10sp"
                                        android:textStyle="bold"
                                        android:paddingStart="6dp"
                                        android:paddingEnd="6dp"
                                        android:paddingTop="2dp"
                                        android:paddingBottom="2dp"
                                        android:background="@drawable/bg_cagr_pct_badge" />

                                </LinearLayout>

                                <!-- Vertical divider -->
                                <View
                                    android:layout_width="1dp"
                                    android:layout_height="match_parent"
                                    android:background="#1AFFFFFF" />

                                <!-- 5Y -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:paddingStart="12dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="5Y"
                                        android:textColor="#80FFFFFF"
                                        android:textSize="10sp"
                                        android:layout_marginBottom="2dp" />

                                    <TextView
                                        android:id="@+id/tvCagrValue5y"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="--"
                                        android:textColor="@color/white"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:layout_marginBottom="4dp" />

                                    <TextView
                                        android:id="@+id/tvCagrPct5y"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="--%"
                                        android:textColor="@color/metals_cagr_badge_text"
                                        android:textSize="10sp"
                                        android:textStyle="bold"
                                        android:paddingStart="6dp"
                                        android:paddingEnd="6dp"
                                        android:paddingTop="2dp"
                                        android:paddingBottom="2dp"
                                        android:background="@drawable/bg_cagr_pct_badge" />

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Syncing indicator -->
                        <TextView
                            android:id="@+id/tvCagrSyncing"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Computing CAGR…"
                            android:textColor="#AAFFFFFF"
                            android:textSize="12sp"
                            android:visibility="gone" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Error / Empty state -->
                <TextView
                    android:id="@+id/tvEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No holdings yet.\nTap + to add your first gold holding."
                    android:textColor="@color/metals_label_muted"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="32dp"
                    android:visibility="gone" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="32dp"
                    android:visibility="gone" />

                <!-- Holdings RecyclerView (adapter renders section headers) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvHoldings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false"
                    android:paddingBottom="8dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddHolding"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:src="@drawable/ic_add"
            android:contentDescription="Add holding"
            app:backgroundTint="@color/card_dark_teal"
            app:tint="@android:color/white" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</FrameLayout>

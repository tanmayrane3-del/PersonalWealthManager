<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_bg"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="12dp"
    android:paddingBottom="32dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#40000000"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fetch SMS from Inbox"
        android:textSize="18sp"
        android:textColor="@color/text_dark"
        android:textStyle="bold" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select how far back to scan. Already captured SMS will be skipped."
        android:textSize="13sp"
        android:textColor="#88000000"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp" />

    <!-- Time range radio group -->
    <RadioGroup
        android:id="@+id/rgTimeRange"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/rb1h"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Last 1 hour"
            android:textSize="15sp"
            android:textColor="@color/text_dark"
            android:buttonTint="@color/text_dark"
            android:gravity="center_vertical" />

        <RadioButton
            android:id="@+id/rb6h"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Last 6 hours"
            android:textSize="15sp"
            android:textColor="@color/text_dark"
            android:buttonTint="@color/text_dark"
            android:gravity="center_vertical" />

        <RadioButton
            android:id="@+id/rb12h"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Last 12 hours"
            android:textSize="15sp"
            android:textColor="@color/text_dark"
            android:buttonTint="@color/text_dark"
            android:gravity="center_vertical" />

        <RadioButton
            android:id="@+id/rb24h"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Last 24 hours"
            android:textSize="15sp"
            android:textColor="@color/text_dark"
            android:buttonTint="@color/text_dark"
            android:gravity="center_vertical"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rb48h"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Last 48 hours"
            android:textSize="15sp"
            android:textColor="@color/text_dark"
            android:buttonTint="@color/text_dark"
            android:gravity="center_vertical" />

        <RadioButton
            android:id="@+id/rb72h"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Last 72 hours"
            android:textSize="15sp"
            android:textColor="@color/text_dark"
            android:buttonTint="@color/text_dark"
            android:gravity="center_vertical" />

    </RadioGroup>

    <!-- Status / result text -->
    <TextView
        android:id="@+id/tvFetchStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:textSize="13sp"
        android:textColor="#88000000"
        android:layout_marginTop="12dp" />

    <!-- Fetch Now button -->
    <Button
        android:id="@+id/btnFetchNow"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Fetch Now"
        android:textColor="@android:color/white"
        android:background="@drawable/button_filled"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginTop="20dp" />

</LinearLayout>

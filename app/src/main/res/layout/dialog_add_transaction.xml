<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/gradient_background"
    android:padding="8dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/card_medium_teal"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Dialog Header with Title and Close Button -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:paddingTop="8dp"
                android:paddingBottom="20dp">

                <!-- Dialog Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Add Transaction"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:fontFamily="sans-serif"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

                <!-- Close Button -->
                <ImageView
                    android:id="@+id/btnCloseDialog"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:contentDescription="Close"
                    android:padding="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@android:color/white"
                    android:clickable="true"
                    android:focusable="true" />

            </RelativeLayout>

            <!-- Transaction Type -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Transaction Type *"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@color/card_light_teal"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:endIconTint="@color/text_dark"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/actvTransactionType"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:inputType="text"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:dropDownHeight="wrap_content"
                    android:completionThreshold="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Amount -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Amount (₹) *"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@color/card_light_teal"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter amount"
                    android:inputType="numberDecimal"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Category -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Category *"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@color/card_light_teal"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:endIconTint="@color/text_dark"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/actvCategory"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:inputType="text"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:dropDownHeight="wrap_content"
                    android:completionThreshold="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Source/Recipient -->
            <TextView
                android:id="@+id/tvSourceRecipientLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Source *"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSourceRecipient"
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@color/card_light_teal"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:endIconTint="@color/text_dark"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/actvSourceRecipient"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:inputType="text"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:dropDownHeight="wrap_content"
                    android:completionThreshold="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Date -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date *"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:id="@+id/datePickerLayout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:background="@drawable/spinner_background_teal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvSelectedDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Select Date"
                    android:textSize="16sp"
                    android:textColor="@color/text_dark" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_calendar"
                    android:contentDescription="Calendar" />
            </LinearLayout>

            <!-- Time -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Time *"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:id="@+id/timePickerLayout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:background="@drawable/spinner_background_teal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvSelectedTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Select Time"
                    android:textSize="16sp"
                    android:textColor="@color/text_dark" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    android:contentDescription="Clock" />
            </LinearLayout>

            <!-- Payment Method -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Payment Method *"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@color/card_light_teal"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:endIconTint="@color/text_dark"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/actvPaymentMethod"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:inputType="text"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:dropDownHeight="wrap_content"
                    android:completionThreshold="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Transaction Reference (Optional) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Transaction Reference (Optional)"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@color/card_light_teal"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTransactionReference"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g., TXN123456, Cheque #789"
                    android:inputType="text"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tags (Optional) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tags (Optional)"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@color/card_light_teal"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g., recurring, urgent, work"
                    android:inputType="text"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Notes (Optional) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notes (Optional)"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@color/card_light_teal"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Add notes..."
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top|start"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="24dp">

                <!-- Clear Button -->
                <Button
                    android:id="@+id/btnClear"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Clear"
                    android:textColor="@color/text_dark"
                    android:background="@drawable/button_outline"
                    android:layout_marginEnd="8dp"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <!-- Add Button -->
                <Button
                    android:id="@+id/btnAdd"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Add"
                    android:textColor="@android:color/white"
                    android:background="@drawable/button_filled"
                    android:layout_marginStart="8dp"
                    android:textStyle="bold"
                    android:textSize="16sp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp"
            android:paddingTop="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:contentDescription="Back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Add Liability"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── SECTION: LOAN DETAILS ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LOAN DETAILS"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp" />

        <!-- Loan Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loan Type *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerLoanType"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/spinner_background_teal"
            android:paddingHorizontal="12dp" />

        <!-- Lender Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lender Name *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etLenderName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_background"
            android:hint="e.g. HDFC Bank, SBI"
            android:textColorHint="#88000000"
            android:textColor="#1A1A1A"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:inputType="textCapWords" />

        <!-- Account Number -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Account No. (optional)"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etLoanAccountNumber"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_background"
            android:hint="e.g. HDFC0012345678"
            android:textColorHint="#88000000"
            android:textColor="#1A1A1A"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:inputType="textCapCharacters" />

        <!-- Interest Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Interest Type *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerInterestType"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/spinner_background_teal"
            android:paddingHorizontal="12dp" />

        <!-- Section divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#26FFFFFF"
            android:layout_marginBottom="20dp" />

        <!-- ── SECTION: LOAN PARAMETERS ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LOAN PARAMETERS"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp" />

        <!-- Loan Amount -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loan Amount (₹) *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etOriginalAmount"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_background"
            android:hint="e.g. 12,06,542"
            android:textColorHint="#88000000"
            android:textColor="#1A1A1A"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:inputType="numberDecimal" />

        <!-- Interest Rate -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Interest Rate (% p.a.) *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etInterestRate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_background"
            android:hint="e.g. 8.7"
            android:textColorHint="#88000000"
            android:textColor="#1A1A1A"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:inputType="numberDecimal" />

        <!-- Tenure -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tenure (months) *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etTenureMonths"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_background"
            android:hint="e.g. 60"
            android:textColorHint="#88000000"
            android:textColor="#1A1A1A"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:inputType="number" />

        <!-- Start Date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loan Start Date *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvStartDate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/edittext_background"
            android:text="Tap to select date"
            android:textColor="#88000000"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true" />

        <!-- Calculate Button -->
        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/button_primary"
            android:text="CALCULATE STATUS"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- ── LOAN STATUS CARD (hidden until calculated) ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLoanStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#0D2A2A">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LOAN STATUS"
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="14dp" />

                <!-- Monthly EMI -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Monthly EMI"
                        android:textColor="#99FFFFFF"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tvStatusEmi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- EMI Due Day -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="EMI Due Day"
                        android:textColor="#99FFFFFF"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tvStatusEmiDueDay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Loan Ends -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Loan Ends"
                        android:textColor="#99FFFFFF"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tvStatusLoanEnd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Total Interest -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Interest"
                        android:textColor="#99FFFFFF"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tvStatusTotalInterest"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#26FFFFFF"
                    android:layout_marginBottom="14dp" />

                <!-- Outstanding Today (highlighted) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Outstanding Today"
                        android:textColor="#99FFFFFF"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tvStatusOutstanding"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#00E5CC"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- EMIs Paid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="EMIs Paid"
                        android:textColor="#99FFFFFF"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tvStatusEmisPaid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- EMIs Remaining -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="EMIs Remaining"
                        android:textColor="#99FFFFFF"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tvStatusEmisRemaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Section divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#26FFFFFF"
            android:layout_marginBottom="20dp" />

        <!-- ── OPTIONAL / EDIT FIELDS ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OPTIONAL"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp" />

        <!-- Status (edit mode only) -->
        <LinearLayout
            android:id="@+id/layoutStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loan Status"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinnerStatus"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/spinner_background_teal"
                android:paddingHorizontal="12dp" />
        </LinearLayout>

        <!-- Linked Asset -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Linked Asset"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerLinkedAsset"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/spinner_background_teal"
            android:paddingHorizontal="12dp" />

        <!-- Notes -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notes"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etNotes"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/edittext_background"
            android:hint="Any additional notes..."
            android:textColorHint="#88000000"
            android:textColor="#1A1A1A"
            android:textSize="15sp"
            android:padding="12dp"
            android:gravity="top"
            android:inputType="textMultiLine" />

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/button_primary"
            android:text="Save Liability"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Delete Button (edit mode only) -->
        <Button
            android:id="@+id/btnDelete"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/button_delete"
            android:text="Delete Liability"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp"
            android:paddingTop="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:contentDescription="Back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Add Liability"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Loan Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loan Type *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerLoanType"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/spinner_background_teal"
            android:paddingHorizontal="12dp" />

        <!-- Lender Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lender Name *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etLenderName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_background"
            android:hint="e.g. HDFC Bank, SBI"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:inputType="textCapWords" />

        <!-- Loan Account Number (optional) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loan Account Number (optional)"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etLoanAccountNumber"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_background"
            android:hint="e.g. HDFC0012345678"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:inputType="textCapCharacters" />

        <!-- Interest Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Interest Type *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerInterestType"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/spinner_background_teal"
            android:paddingHorizontal="12dp" />

        <!-- Interest Rate -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Interest Rate (% p.a.) *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etInterestRate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_background"
            android:hint="e.g. 8.5"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:inputType="numberDecimal" />

        <!-- Original Amount -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Original Loan Amount (₹) *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etOriginalAmount"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_background"
            android:hint="e.g. 5000000"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:inputType="numberDecimal" />

        <!-- Outstanding Principal -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Outstanding Principal (₹) *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etOutstandingPrincipal"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_background"
            android:hint="Current outstanding balance"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:inputType="numberDecimal" />

        <!-- EMI Amount -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monthly EMI (₹) *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etEmiAmount"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_background"
            android:hint="e.g. 45000"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:inputType="numberDecimal" />

        <!-- EMI Due Day (optional) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMI Due Day (1-31, optional)"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etEmiDueDay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_background"
            android:hint="e.g. 5"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:inputType="number" />

        <!-- Start Date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loan Start Date *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvStartDate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_background"
            android:text="Tap to select date"
            android:textColor="#88FFFFFF"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true" />

        <!-- Tenure -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tenure (months) *"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etTenureMonths"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_background"
            android:hint="e.g. 240 (20 years)"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:inputType="number" />

        <!-- Linked Physical Asset (optional) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Linked Asset (optional)"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerLinkedAsset"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/spinner_background_teal"
            android:paddingHorizontal="12dp" />

        <!-- Status (edit mode only) -->
        <LinearLayout
            android:id="@+id/layoutStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinnerStatus"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/spinner_background_teal"
                android:paddingHorizontal="12dp" />
        </LinearLayout>

        <!-- Notes -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notes (optional)"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etNotes"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/edittext_background"
            android:hint="Any additional notes..."
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:padding="12dp"
            android:gravity="top"
            android:inputType="textMultiLine" />

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/button_primary"
            android:text="Save Liability"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Delete Button (edit mode only) -->
        <Button
            android:id="@+id/btnDelete"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/button_delete"
            android:text="Delete Liability"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>

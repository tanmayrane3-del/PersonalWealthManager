<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFB"
    android:fitsSystemWindows="true">

    <!-- ── BOTTOM ACTION BAR (declared first for layout_above reference) ── -->
    <LinearLayout
        android:id="@+id/bottomActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#F8FAFB"
        android:elevation="8dp"
        android:padding="16dp"
        android:paddingBottom="20dp"
        android:gravity="center_vertical">

        <!-- Divider line at top of bottom bar -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Save Liability"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/teal_700"
            app:cornerRadius="26dp"
            app:elevation="0dp"
            style="@style/Widget.MaterialComponents.Button" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="12dp"
            app:icon="@drawable/ic_edit_tx_delete"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:backgroundTint="#FFDAD6"
            app:iconTint="#BA1A1A"
            app:cornerRadius="26dp"
            app:elevation="0dp"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.Icon" />

    </LinearLayout>

    <!-- ── TOP APP BAR ── -->
    <LinearLayout
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F8FAFB"
        android:elevation="4dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back_arrow"
            android:contentDescription="Back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:text="Add Liability"
            android:textColor="@color/teal_800"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <ImageView
            android:id="@+id/btnDeleteHeader"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_edit_tx_delete"
            android:contentDescription="Delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:tint="@color/gray_500"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ── MAIN SCROLL CONTENT ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topAppBar"
        android:layout_above="@id/bottomActionBar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- SECTION 1: LOAN DETAILS                                     -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_section_gray"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loan Details"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp" />

                <!-- Loan Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loan Type *"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/spinnerLoanType"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/edittext_background"
                    android:paddingHorizontal="14dp" />

                <!-- Lender Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lender Name *"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etLenderName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/edittext_background"
                    android:hint="e.g. HDFC Bank, SBI"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:paddingHorizontal="14dp"
                    android:inputType="textCapWords" />

                <!-- Account Number -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account No."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etLoanAccountNumber"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/edittext_background"
                    android:hint="e.g. XXXX XXXX 1234"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:paddingHorizontal="14dp"
                    android:inputType="textCapCharacters" />

                <!-- Interest Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Interest Type *"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/spinnerInterestType"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_background"
                    android:paddingHorizontal="14dp" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- SECTION 2: LOAN PARAMETERS                                  -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_section_gray"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loan Parameters"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp" />

                <!-- Loan Amount with ₹ prefix -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loan Amount *"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tvRupeePrefix"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="14dp"
                        android:text="₹"
                        android:textColor="@color/text_secondary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etOriginalAmount"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/edittext_background"
                        android:hint="e.g. 1206542"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingStart="36dp"
                        android:paddingEnd="14dp"
                        android:inputType="numberDecimal"
                        android:gravity="center_vertical" />

                </RelativeLayout>

                <!-- Interest Rate + Tenure (2 columns) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Interest Rate *"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp">

                            <EditText
                                android:id="@+id/etInterestRate"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/edittext_background"
                                android:hint="8.7"
                                android:textColorHint="@color/text_hint"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:paddingStart="14dp"
                                android:paddingEnd="32dp"
                                android:inputType="numberDecimal"
                                android:gravity="center_vertical" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:layout_marginEnd="12dp"
                                android:text="%"
                                android:textColor="@color/text_secondary"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </RelativeLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tenure (Months) *"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp" />

                        <EditText
                            android:id="@+id/etTenureMonths"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/edittext_background"
                            android:hint="60"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="14dp"
                            android:inputType="number" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Loan Start Date -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loan Start Date *"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:id="@+id/tvStartDate"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/edittext_background"
                        android:text="Tap to select date"
                        android:textColor="@color/text_hint"
                        android:textSize="15sp"
                        android:paddingHorizontal="14dp"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="14dp"
                        android:src="@drawable/ic_calendar"
                        android:tint="@color/gray_500"
                        android:contentDescription="Pick date" />
                </RelativeLayout>

                <!-- Calculate Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCalculate"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Calculate Status"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_analytics"
                    app:iconGravity="textStart"
                    app:backgroundTint="@color/teal_700"
                    app:cornerRadius="26dp"
                    app:elevation="0dp"
                    style="@style/Widget.MaterialComponents.Button" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- SECTION 3: CALCULATED STATUS (hidden until calculated)      -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLoanStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F2F4F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calculated Status"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="14dp" />

                    <!-- Hero Outstanding Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#004F45">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Outstanding Today"
                                android:textColor="#94E5D5"
                                android:textSize="13sp"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvStatusOutstanding"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textColor="@android:color/white"
                                android:textSize="30sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="10dp" />

                            <!-- EMIs Paid + Remaining row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="10dp">

                                <TextView
                                    android:id="@+id/tvStatusEmisPaid"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="0 EMIs Paid"
                                    android:textColor="#CCffffff"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/tvStatusEmisRemaining"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 Remaining"
                                    android:textColor="#CCffffff"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- EMI Progress Bar -->
                            <ProgressBar
                                android:id="@+id/progressEmi"
                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:progressDrawable="@drawable/bg_emi_progress"
                                android:max="100"
                                android:progress="0" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 2×2 Stat Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Row 1 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="@drawable/spinner_background"
                                android:padding="14dp"
                                android:layout_marginEnd="5dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="MONTHLY EMI"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.08"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/tvStatusEmi"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹0"
                                    android:textColor="@color/text_primary"
                                    android:textSize="17sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="@drawable/spinner_background"
                                android:padding="14dp"
                                android:layout_marginStart="5dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="TOTAL INTEREST"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.08"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/tvStatusTotalInterest"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹0"
                                    android:textColor="@color/text_primary"
                                    android:textSize="17sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                        </LinearLayout>

                        <!-- Row 2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="@drawable/spinner_background"
                                android:padding="14dp"
                                android:layout_marginEnd="5dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="EMI DUE DAY"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.08"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/tvStatusEmiDueDay"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textColor="@color/text_primary"
                                    android:textSize="17sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="@drawable/spinner_background"
                                android:padding="14dp"
                                android:layout_marginStart="5dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LOAN ENDS"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.08"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/tvStatusLoanEnd"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textColor="@color/text_primary"
                                    android:textSize="17sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- SECTION 4: LINKED ASSET (hidden, shown for car/home loans)  -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutAssetLinking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_section_gray"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/tvAssetLinkingTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Linked Asset *"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Existing assets picker (shown when matching assets exist) -->
                <LinearLayout
                    android:id="@+id/layoutExistingAssets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select existing asset:"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <Spinner
                        android:id="@+id/spExistingAssets"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edittext_background"
                        android:paddingHorizontal="14dp" />
                </LinearLayout>

                <!-- Linked Asset Confirmation Chip -->
                <TextView
                    android:id="@+id/tvLinkedAssetChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="14dp"
                    android:background="@drawable/bg_linked_asset"
                    android:text="✓ Linked to: Asset Name"
                    android:textColor="@color/teal_700"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone" />

                <!-- Link Another / Add New Asset Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddNewAsset"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="+ Link Another Car"
                    android:textColor="@color/teal_800"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/card_light_teal"
                    app:cornerRadius="8dp"
                    app:elevation="0dp"
                    style="@style/Widget.MaterialComponents.Button" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- SECTION 5: ADDITIONAL INFORMATION                           -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_section_gray"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Additional Information"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp" />

                <!-- Active Status toggle (edit mode only) -->
                <LinearLayout
                    android:id="@+id/layoutStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Switch Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/edittext_background"
                        android:padding="14dp"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active Status"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Include in net worth calculations"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <Switch
                            android:id="@+id/switchActiveStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:thumbTint="@color/white"
                            android:trackTint="@color/teal_700" />
                    </LinearLayout>

                    <!-- Hidden spinner for status (3-option compat) -->
                    <Spinner
                        android:id="@+id/spinnerStatus"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/edittext_background"
                        android:paddingHorizontal="14dp"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- Notes -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notes (Optional)"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etNotes"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@drawable/edittext_background"
                    android:hint="Add any notes regarding this loan..."
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:padding="14dp"
                    android:gravity="top"
                    android:inputType="textMultiLine" />

            </LinearLayout>

            <!-- Hidden cancel button (kept for Activity code compat) -->
            <Button
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>

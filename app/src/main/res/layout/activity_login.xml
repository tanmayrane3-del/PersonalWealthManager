<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFB"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Top Navigation Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="#F8FAFB"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_drawer_bank"
                    android:tint="#004F45"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Personal Wealth Manager"
                    android:textColor="#004F45"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_bold" />

            </LinearLayout>

            <!-- Center Content Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <!-- Error Banner (hidden by default) -->
                <include
                    android:id="@+id/errorBanner"
                    layout="@layout/error_banner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp" />

                <!-- Login Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/loginCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardMaxElevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="28dp"
                        android:paddingEnd="28dp"
                        android:paddingTop="36dp"
                        android:paddingBottom="36dp">

                        <!-- Welcome heading -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Welcome back"
                            android:textColor="#191C1D"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textAlignment="center"
                            android:fontFamily="@font/poppins_bold"
                            android:layout_marginBottom="8dp" />

                        <!-- Subtitle -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Enter your credentials to access your secure vault"
                            android:textColor="#3E4946"
                            android:textSize="14sp"
                            android:textAlignment="center"
                            android:lineSpacingMultiplier="1.3"
                            android:layout_marginBottom="32dp" />

                        <!-- EMAIL label -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="EMAIL"
                            android:textColor="#3E4946"
                            android:textSize="11sp"
                            android:letterSpacing="0.1"
                            android:textAllCaps="true"
                            android:layout_marginStart="4dp"
                            android:layout_marginBottom="6dp" />

                        <!-- Email Input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/emailInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp"
                            app:hintEnabled="false"
                            app:boxBackgroundColor="#E6E8E9"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textEmailAddress"
                                android:hint="name@company.com"
                                android:textColor="#191C1D"
                                android:textColorHint="#6E7976"
                                android:textSize="15sp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- PASSWORD row: label + FORGOT? link -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="PASSWORD"
                                android:textColor="#3E4946"
                                android:textSize="11sp"
                                android:letterSpacing="0.1"
                                android:textAllCaps="true"
                                android:layout_marginStart="4dp" />

                            <TextView
                                android:id="@+id/tvForgotPassword"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FORGOT?"
                                android:textColor="#004F45"
                                android:textSize="10sp"
                                android:letterSpacing="0.08"
                                android:textAllCaps="true"
                                android:textStyle="bold"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp" />
                        </LinearLayout>

                        <!-- Password Input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/passwordInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="28dp"
                            app:hintEnabled="false"
                            app:boxBackgroundColor="#E6E8E9"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:endIconMode="password_toggle"
                            app:endIconTint="#6E7976">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPassword"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword"
                                android:hint="••••••••"
                                android:textColor="#191C1D"
                                android:textColorHint="#6E7976"
                                android:textSize="15sp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Login Button (pill) -->
                        <Button
                            android:id="@+id/btnLogin"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:backgroundTint="#00695C"
                            android:text="Login"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="28dp"
                            app:cornerRadius="100dp" />

                        <!-- Register Link -->
                        <TextView
                            android:id="@+id/tvRegister"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="New user? Register here"
                            android:textColor="#3E4946"
                            android:textSize="14sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="© 2024 PERSONAL WEALTH MANAGER"
                    android:textColor="#3E4946"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/tvPrivacyPolicy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/privacy_policy"
                    android:textColor="#3E4946"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:textAllCaps="true" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Loading overlay -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</FrameLayout>

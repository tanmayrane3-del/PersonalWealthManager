<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gradient_start">

    <!-- Main Content Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:background="@drawable/gradient_background">

        <!-- Main Content -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- App Bar -->
            <LinearLayout
                android:id="@+id/appBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp"
                android:paddingTop="24dp"
                android:gravity="center_vertical"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Title -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/transactions"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Filter Button -->
                <Button
                    android:id="@+id/btnFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="@string/filters"
                    android:textColor="@android:color/white"
                    android:background="@color/filter_button_bg"
                    android:drawableLeft="@drawable/ic_filter"
                    android:drawablePadding="8dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <!-- View Button -->
                <Button
                    android:id="@+id/btnView"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="@string/view"
                    android:textColor="@android:color/white"
                    android:background="@color/filter_button_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginStart="8dp" />

                <!-- Burger Menu -->
                <ImageView
                    android:id="@+id/btnMenu"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_menu"
                    android:contentDescription="@string/menu"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Transactions List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTransactions"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false"
                app:layout_constraintTop_toBottomOf="@id/appBar"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Empty State -->
            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_transactions"
                android:textColor="@color/text_muted"
                android:textSize="16sp"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Loading State -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Chart Container (replaces list in view mode) -->
            <LinearLayout
                android:id="@+id/chartContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/appBar"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Chart header: date range + back button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:gravity="center_vertical"
                    android:background="#22FFFFFF">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvChartTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:text="@string/weekly_view" />

                        <TextView
                            android:id="@+id/tvChartDateRange"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"
                            android:text="@string/all_transactions" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnBackToList"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/list_view"
                        android:textColor="@android:color/white"
                        android:background="@color/filter_button_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Scrollable chart content -->
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:fillViewport="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingBottom="80dp">

                        <!-- Line Chart (weekly / daily / monthly) -->
                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/lineChart"
                            android:layout_width="match_parent"
                            android:layout_height="340dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"
                            android:visibility="gone" />

                        <!-- No-data label for line chart -->
                        <TextView
                            android:id="@+id/tvLineChartEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:gravity="center"
                            android:text="@string/no_data_for_period"
                            android:textColor="#CCFFFFFF"
                            android:textSize="14sp"
                            android:visibility="gone" />

                        <!-- Pie Charts Container (source &amp; recipient) -->
                        <LinearLayout
                            android:id="@+id/pieChartsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/income_by_category"
                                android:textColor="@android:color/white"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="4dp" />

                            <com.github.mikephil.charting.charts.PieChart
                                android:id="@+id/pieIncomeByCategory"
                                android:layout_width="match_parent"
                                android:layout_height="260dp"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/expense_by_category"
                                android:textColor="@android:color/white"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="4dp" />

                            <com.github.mikephil.charting.charts.PieChart
                                android:id="@+id/pieExpenseByCategory"
                                android:layout_width="match_parent"
                                android:layout_height="260dp"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/income_by_source"
                                android:textColor="@android:color/white"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="4dp" />

                            <com.github.mikephil.charting.charts.PieChart
                                android:id="@+id/pieIncomeBySource"
                                android:layout_width="match_parent"
                                android:layout_height="260dp"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/expense_by_recipient"
                                android:textColor="@android:color/white"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="4dp" />

                            <com.github.mikephil.charting.charts.PieChart
                                android:id="@+id/pieExpenseByRecipient"
                                android:layout_width="match_parent"
                                android:layout_height="260dp"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="8dp" />

                        </LinearLayout>

                    </LinearLayout>

                </ScrollView>

            </LinearLayout>

            <!-- Floating Action Button (FAB) -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAddTransaction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="24dp"
                android:src="@android:drawable/ic_input_add"
                android:contentDescription="Add Transaction"
                app:backgroundTint="@color/card_medium_teal"
                app:tint="@android:color/white"
                app:elevation="8dp"
                app:pressedTranslationZ="16dp"
                app:borderWidth="0dp"
                app:rippleColor="@color/card_light_teal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Filter Drawer Overlay (inside main content) -->
        <FrameLayout
            android:id="@+id/filterDrawerContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            android:background="#80000000"
            android:elevation="10dp">

            <LinearLayout
                android:id="@+id/filterDrawer"
                android:layout_width="320dp"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:orientation="vertical">

                <include layout="@layout/drawer_filters" />

            </LinearLayout>

        </FrameLayout>

    </FrameLayout>

    <!-- Navigation Menu Drawer (slides from right) -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/card_medium_teal"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/drawer_header" />

</androidx.drawerlayout.widget.DrawerLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tx_bg">

    <!-- Main Content Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:background="@color/tx_bg">

        <!-- Blurrable content wrapper (main content + bottom nav) -->
        <FrameLayout
            android:id="@+id/mainContentWrapper"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <!-- Main Content -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Header / App Bar -->
            <LinearLayout
                android:id="@+id/appBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical"
                android:background="@color/tx_bg"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Back Button -->
                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_back_arrow"
                    android:contentDescription="Back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Title -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="@string/transactions"
                    android:textColor="@color/tx_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Filter button: oval pill bg + icon + "FILTER" label -->
                <LinearLayout
                    android:id="@+id/btnFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_filter_pill"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_filter"
                        android:tint="@color/tx_text_secondary"
                        android:contentDescription="Filter" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="FILTER"
                        android:textColor="@color/tx_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04" />

                </LinearLayout>

            </LinearLayout>

            <!-- Summary Cards Row -->
            <LinearLayout
                android:id="@+id/cardSummaryRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="4dp"
                app:layout_constraintTop_toBottomOf="@id/appBar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Current Ledger Card (dark green) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_current_ledger_card"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT LEDGER"
                        android:textColor="#CCFFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tvCurrentLedgerBalance"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="2dp"
                        android:text="₹0.00"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:gravity="center_vertical" />

                    <TextView
                        android:id="@+id/tvCurrentLedgerUpdated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Updated just now"
                        android:textColor="#CCFFFFFF"
                        android:textSize="9sp" />

                </LinearLayout>

                <!-- Analysis Card (white, clickable) -->
                <LinearLayout
                    android:id="@+id/cardAnalysis"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_analysis_card"
                    android:padding="13dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VIEW FULL REPORT"
                        android:textColor="@color/tx_text_secondary"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="2dp"
                        android:text="Analysis"
                        android:textColor="@color/tx_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center_vertical" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Review →"
                        android:textColor="@color/tx_amount_income"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- Transactions List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTransactions"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:paddingTop="8dp"
                android:paddingBottom="88dp"
                android:clipToPadding="false"
                app:layout_constraintTop_toBottomOf="@id/cardSummaryRow"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Empty State -->
            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_transactions"
                android:textColor="@color/tx_text_secondary"
                android:textSize="16sp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/cardSummaryRow"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Loading State -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Chart Container (replaces list when Analysis is tapped) -->
            <LinearLayout
                android:id="@+id/chartContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/appBar"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Chart header bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:gravity="center_vertical"
                    android:background="#F0F8F7">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvChartTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/tx_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:text="@string/weekly_view" />

                        <TextView
                            android:id="@+id/tvChartDateRange"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/tx_text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"
                            android:text="@string/all_transactions" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnBackToList"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/list_view"
                        android:textColor="@color/white"
                        android:textAllCaps="false"
                        android:background="@drawable/bg_filter_pill_primary"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textSize="12sp"
                        android:stateListAnimator="@null" />

                </LinearLayout>

                <!-- Scrollable chart content -->
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:fillViewport="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingBottom="80dp">

                        <!-- Line Chart -->
                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/lineChart"
                            android:layout_width="match_parent"
                            android:layout_height="340dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"
                            android:visibility="gone" />

                        <!-- No-data label for line chart -->
                        <TextView
                            android:id="@+id/tvLineChartEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:gravity="center"
                            android:text="@string/no_data_for_period"
                            android:textColor="@color/tx_text_secondary"
                            android:textSize="14sp"
                            android:visibility="gone" />

                        <!-- Pie Charts Container -->
                        <LinearLayout
                            android:id="@+id/pieChartsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/income_by_category"
                                android:textColor="@color/tx_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="4dp" />

                            <com.github.mikephil.charting.charts.PieChart
                                android:id="@+id/pieIncomeByCategory"
                                android:layout_width="match_parent"
                                android:layout_height="260dp"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/expense_by_category"
                                android:textColor="@color/tx_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="4dp" />

                            <com.github.mikephil.charting.charts.PieChart
                                android:id="@+id/pieExpenseByCategory"
                                android:layout_width="match_parent"
                                android:layout_height="260dp"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/income_by_source"
                                android:textColor="@color/tx_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="4dp" />

                            <com.github.mikephil.charting.charts.PieChart
                                android:id="@+id/pieIncomeBySource"
                                android:layout_width="match_parent"
                                android:layout_height="260dp"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/expense_by_recipient"
                                android:textColor="@color/tx_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="4dp" />

                            <com.github.mikephil.charting.charts.PieChart
                                android:id="@+id/pieExpenseByRecipient"
                                android:layout_width="match_parent"
                                android:layout_height="260dp"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="8dp" />

                        </LinearLayout>

                    </LinearLayout>

                </ScrollView>

            </LinearLayout>

            <!-- Floating Action Button — sits above the bottom nav bar -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAddTransaction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="82dp"
                android:src="@android:drawable/ic_input_add"
                android:contentDescription="Add Transaction"
                app:backgroundTint="@color/tx_primary"
                app:tint="@android:color/white"
                app:elevation="8dp"
                app:pressedTranslationZ="16dp"
                app:borderWidth="0dp"
                app:rippleColor="#33005C4B"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <include
            layout="@layout/layout_bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom" />

        </FrameLayout><!-- end mainContentWrapper -->

        <!-- Filter Drawer Overlay — elevation > bottom nav (12dp) so it renders on top -->
        <FrameLayout
            android:id="@+id/filterDrawerContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            android:background="#80000000"
            android:elevation="20dp">

            <LinearLayout
                android:id="@+id/filterDrawer"
                android:layout_width="320dp"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:orientation="vertical">

                <include layout="@layout/drawer_filters" />

            </LinearLayout>

        </FrameLayout>

    </FrameLayout>

    <!-- Navigation Menu Drawer (opened via bottom nav "Menu" tab) -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/drawer_bg"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/drawer_header" />

</androidx.drawerlayout.widget.DrawerLayout>

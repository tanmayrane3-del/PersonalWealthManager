<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="36dp">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="28dp"
            android:background="@drawable/bs_drag_handle" />

        <!-- Hidden close button (retained for Activity compatibility) -->
        <ImageView
            android:id="@+id/btnCloseDialog"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- Icon circle -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bs_icon_circle">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_drawer_category"
                app:tint="@color/teal_800" />

        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/edit_category"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:gravity="center"
            android:fontFamily="sans-serif-medium" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Customise the name, description and emoji icon for this category."
            android:textSize="13sp"
            android:textColor="@color/drawer_item_text"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="28dp" />

        <!-- Category Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CATEGORY NAME"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/drawer_item_subtext"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bs_field_bg">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCategoryName"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:hint="e.g. Groceries, Rent, Salary"
                android:inputType="textCapWords"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />
        </FrameLayout>

        <!-- Description (Optional) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DESCRIPTION"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/drawer_item_subtext"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Optional"
                android:textSize="11sp"
                android:textColor="@color/text_hint" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bs_field_bg">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCategoryDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:background="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:gravity="top|start"
                android:hint="Short description of this category"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />
        </FrameLayout>

        <!-- Icon / Emoji -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ICON (EMOJI)"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/drawer_item_subtext"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Optional"
                android:textSize="11sp"
                android:textColor="@color/text_hint" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bs_field_bg">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:hint="Tap to enter an emoji  e.g. 🏠"
                android:inputType="textNoSuggestions"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_hint"
                android:textSize="22sp"
                android:maxLength="10" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter a single emoji to use as the category icon."
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="20dp" />

        <!-- Budget Type label row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="BUDGET TYPE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/drawer_item_subtext"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Optional"
                android:textSize="11sp"
                android:textColor="@color/text_hint" />
        </LinearLayout>

        <!-- Income Type toggle: Primary | Passive | One-time -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleIncomeType"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="4dp"
            app:singleSelection="true"
            app:selectionRequired="false"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrimary"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Primary"
                android:textSize="12sp"
                android:textColor="@color/toggle_btn_text"
                app:backgroundTint="@color/toggle_btn_bg"
                app:strokeColor="@color/teal_800"
                app:strokeWidth="1.5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPassive"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Passive"
                android:textSize="12sp"
                android:textColor="@color/toggle_btn_text"
                app:backgroundTint="@color/toggle_btn_bg"
                app:strokeColor="@color/teal_800"
                app:strokeWidth="1.5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOneTime"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="One-time"
                android:textSize="12sp"
                android:textColor="@color/toggle_btn_text"
                app:backgroundTint="@color/toggle_btn_bg"
                app:strokeColor="@color/teal_800"
                app:strokeWidth="1.5dp" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Expense Spending Type toggle: Needs | Wants | Savings -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleSpendingType"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="4dp"
            app:singleSelection="true"
            app:selectionRequired="false"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNeeds"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Needs"
                android:textSize="12sp"
                android:textColor="@color/toggle_btn_text"
                app:backgroundTint="@color/toggle_btn_bg"
                app:strokeColor="@color/teal_800"
                app:strokeWidth="1.5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWants"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Wants"
                android:textSize="12sp"
                android:textColor="@color/toggle_btn_text"
                app:backgroundTint="@color/toggle_btn_bg"
                app:strokeColor="@color/teal_800"
                app:strokeWidth="1.5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSavings"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Savings"
                android:textSize="12sp"
                android:textColor="@color/toggle_btn_text"
                app:backgroundTint="@color/toggle_btn_bg"
                app:strokeColor="@color/teal_800"
                app:strokeWidth="1.5dp" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:id="@+id/tvBudgetTypeHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Classifies this category in budget reports."
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="20dp" />

        <!-- Transaction warning -->
        <TextView
            android:id="@+id/tvTransactionWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/warning_orange"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingTop="8dp"
            android:visibility="gone" />

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:indeterminateTint="@color/teal_700"
            android:visibility="gone" />

        <!-- Error message -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/error_red"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingTop="8dp"
            android:visibility="gone" />

        <!-- Action Buttons -->
        <LinearLayout
            android:id="@+id/buttonsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="@string/cancel"
                android:textColor="@color/teal_800"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginEnd="8dp"
                app:strokeColor="@color/teal_800"
                app:strokeWidth="1.5dp"
                app:cornerRadius="28dp"
                app:backgroundTint="@android:color/transparent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="@string/save"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginStart="8dp"
                app:backgroundTint="@color/teal_800"
                app:cornerRadius="28dp"
                app:elevation="0dp" />

        </LinearLayout>

        <!-- Delete Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/delete_category"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="15sp"
            android:visibility="gone"
            app:backgroundTint="@color/error_red"
            app:cornerRadius="28dp"
            app:elevation="0dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>

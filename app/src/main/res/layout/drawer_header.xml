<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card_medium_teal"
    android:padding="16dp">

    <!-- User Email Header -->
    <TextView
        android:id="@+id/tvUserEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="user@example.com"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"
        android:paddingTop="24dp" />

    <!-- Dashboard Button -->
    <Button
        android:id="@+id/btnDashboard"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/dashboard"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@color/card_dark_teal"
        android:layout_marginBottom="12dp" />

    <!-- Transactions Button -->
    <Button
        android:id="@+id/btnTransactions"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/transactions"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@color/card_dark_teal"
        android:layout_marginBottom="12dp" />

    <!-- Management Header Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp"
        android:background="@color/card_dark_teal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnManagement"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="56dp"
            android:text="@string/management"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@android:color/transparent"
            android:gravity="start|center_vertical" />

        <ImageView
            android:id="@+id/ivManagementExpand"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_expand_more"
            android:contentDescription="@string/expand_collapse"
            android:layout_marginEnd="8dp" />
    </LinearLayout>

    <!-- Management Child Items Container -->
    <LinearLayout
        android:id="@+id/managementChildItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingStart="24dp"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnCategoryManagement"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/categories"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:background="@color/card_dark_teal"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp" />

        <Button
            android:id="@+id/btnSourceManagement"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/income_source_management"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:background="@color/card_dark_teal"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp" />

        <Button
            android:id="@+id/btnRecipientManagement"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/recipient_management"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:background="@color/card_dark_teal"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp" />
    </LinearLayout>

    <!-- Logout Button -->
    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/logout"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@color/card_dark_teal" />

</LinearLayout>
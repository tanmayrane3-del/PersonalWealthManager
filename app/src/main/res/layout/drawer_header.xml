<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card_medium_teal"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="8dp"
    android:paddingBottom="12dp">

    <!-- User Email Header -->
    <TextView
        android:id="@+id/tvUserEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="user@example.com"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingBottom="14dp"
        android:paddingStart="4dp" />

    <!-- Dashboard Button -->
    <Button
        android:id="@+id/btnDashboard"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="@string/dashboard"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/drawer_item_bg"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:layout_marginBottom="6dp" />

    <!-- Transactions Button -->
    <Button
        android:id="@+id/btnTransactions"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="@string/transactions"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/drawer_item_bg"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:layout_marginBottom="6dp" />

    <!-- Management Header Button (expandable) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp"
        android:background="@drawable/drawer_item_bg"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnManagement"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:text="@string/management"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@android:color/transparent"
            android:gravity="start|center_vertical" />

        <ImageView
            android:id="@+id/ivManagementExpand"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_expand_more"
            android:contentDescription="@string/expand_collapse"
            android:layout_marginEnd="4dp" />
    </LinearLayout>

    <!-- Management Child Items Container -->
    <LinearLayout
        android:id="@+id/managementChildItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingStart="12dp"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btnCategoryManagement"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:text="@string/categories"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:background="@drawable/drawer_item_bg"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnSourceManagement"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:text="@string/income_source_management"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:background="@drawable/drawer_item_bg"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnRecipientManagement"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:text="@string/recipient_management"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:background="@drawable/drawer_item_bg"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp" />
    </LinearLayout>

    <!-- Net Worth Button -->
    <Button
        android:id="@+id/btnNetWorth"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Net Worth"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/drawer_item_bg"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:layout_marginBottom="6dp" />

    <!-- Assets Header Button (expandable) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp"
        android:background="@drawable/drawer_item_bg"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnAssets"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:text="@string/assets"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@android:color/transparent"
            android:gravity="start|center_vertical" />

        <ImageView
            android:id="@+id/ivAssetsExpand"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_expand_more"
            android:contentDescription="@string/expand_collapse"
            android:layout_marginEnd="4dp" />
    </LinearLayout>

    <!-- Assets Child Items -->
    <LinearLayout
        android:id="@+id/assetsChildItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingStart="12dp"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btnStocks"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:text="@string/stocks"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:background="@drawable/drawer_item_bg"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnMetals"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:text="Metals"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:background="@drawable/drawer_item_bg"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnMutualFunds"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:text="@string/mutual_funds"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:background="@drawable/drawer_item_bg"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnOtherAssets"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:text="Other Assets"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:background="@drawable/drawer_item_bg"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp" />
    </LinearLayout>

    <!-- Liabilities Button -->
    <Button
        android:id="@+id/btnLiabilities"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Liabilities"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/drawer_item_bg"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:layout_marginBottom="6dp" />

    <!-- Setup Demat Header Button (expandable) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp"
        android:background="@drawable/drawer_item_bg"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnSetupDemat"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:text="@string/setup_demat"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@android:color/transparent"
            android:gravity="start|center_vertical" />

        <ImageView
            android:id="@+id/ivSetupDematExpand"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_expand_more"
            android:contentDescription="@string/expand_collapse"
            android:layout_marginEnd="4dp" />
    </LinearLayout>

    <!-- Setup Demat Child Items -->
    <LinearLayout
        android:id="@+id/setupDematChildItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingStart="12dp"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btnConnectZerodha"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:text="@string/connect_zerodha"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:background="@drawable/drawer_item_bg"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp" />
    </LinearLayout>

    <!-- Settings Button -->
    <Button
        android:id="@+id/btnSettings"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="@string/settings"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/drawer_item_bg"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:layout_marginBottom="6dp" />

    <!-- Logout Button -->
    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="@string/logout"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/drawer_item_bg"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp" />

</LinearLayout>

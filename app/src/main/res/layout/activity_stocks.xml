<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ── Main content ───────────────────────────────────────────────── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:background="#F8FAFB">

        <!-- Scrollable page content -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="80dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── App Bar ──────────────────────────────────────────── -->
                <LinearLayout
                    android:id="@+id/appBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:background="@color/white"
                    android:elevation="2dp">

                    <ImageButton
                        android:id="@+id/btnBack"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_back"
                        android:tint="@color/teal_800"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Back" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/stocks"
                        android:textColor="@color/teal_800"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginStart="4dp" />

                    <ImageButton
                        android:id="@+id/btnSync"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_refresh"
                        android:tint="@color/teal_700"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Sync"
                        android:layout_marginEnd="4dp" />

                    <ImageButton
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_bell"
                        android:tint="@color/text_muted"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Notifications" />
                </LinearLayout>

                <!-- ── Page padding wrapper ─────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp">

                    <!-- ── Hero: Portfolio Value card ───────────────────── -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@color/teal_800">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="24dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PORTFOLIO VALUE"
                                android:textColor="#99FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.12"
                                android:layout_marginBottom="6dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/tvPortfolioValue"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="₹0.00"
                                    android:textColor="@color/white"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />

                                <!-- 1D change badge -->
                                <LinearLayout
                                    android:id="@+id/llTrendBadge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:background="@drawable/bg_trend_badge"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp"
                                    android:paddingTop="4dp"
                                    android:paddingBottom="4dp">

                                    <ImageView
                                        android:id="@+id/ivTrendIcon"
                                        android:layout_width="12dp"
                                        android:layout_height="12dp"
                                        android:src="@drawable/ic_trending_up"
                                        android:tint="@color/white"
                                        android:layout_marginEnd="3dp"
                                        android:contentDescription="Trend" />

                                    <TextView
                                        android:id="@+id/tvTrendBadge"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0.00%"
                                        android:textColor="@color/white"
                                        android:textSize="11sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- ── Secondary Stats card (collapsible) ───────────── -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardSecondaryStats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white">

                        <LinearLayout
                            android:id="@+id/cardSecondaryStatsInner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Header row -->
                            <LinearLayout
                                android:id="@+id/headerSecondaryStats"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:padding="20dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?attr/selectableItemBackground">

                                <FrameLayout
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/bg_section_icon"
                                    android:layout_marginEnd="12dp">
                                    <ImageView
                                        android:layout_width="22dp"
                                        android:layout_height="22dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_analytics"
                                        android:tint="@color/text_secondary"
                                        android:contentDescription="Stats" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Secondary Stats"
                                    android:textColor="@color/text_dark"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                                <ImageView
                                    android:id="@+id/ivExpandSecondary"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:src="@drawable/ic_expand_more"
                                    android:tint="@color/text_muted"
                                    android:contentDescription="Expand" />
                            </LinearLayout>

                            <!-- Content (toggled) -->
                            <LinearLayout
                                android:id="@+id/contentSecondaryStats"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:paddingStart="20dp"
                                android:paddingEnd="20dp"
                                android:paddingBottom="20dp"
                                android:visibility="gone">

                                <!-- 3-col: Invested · Total P&L · 1D Change -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:background="@drawable/bg_section_gray"
                                    android:padding="14dp">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="INVESTED"
                                            android:textSize="9sp"
                                            android:textStyle="bold"
                                            android:letterSpacing="0.08"
                                            android:textColor="@color/text_muted" />
                                        <TextView
                                            android:id="@+id/tvTotalInvested"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:textSize="13sp"
                                            android:textStyle="bold"
                                            android:textColor="@color/text_dark"
                                            android:layout_marginTop="2dp"
                                            android:text="₹0.00" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="TOTAL P&amp;L"
                                            android:textSize="9sp"
                                            android:textStyle="bold"
                                            android:letterSpacing="0.08"
                                            android:textColor="@color/text_muted" />
                                        <TextView
                                            android:id="@+id/tvTotalPnl"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:textSize="13sp"
                                            android:textStyle="bold"
                                            android:layout_marginTop="2dp"
                                            android:text="₹0.00" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="1D CHANGE"
                                            android:textSize="9sp"
                                            android:textStyle="bold"
                                            android:letterSpacing="0.08"
                                            android:textColor="@color/text_muted" />
                                        <TextView
                                            android:id="@+id/tvDayChange"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:textSize="13sp"
                                            android:textStyle="bold"
                                            android:layout_marginTop="2dp"
                                            android:text="₹0.00" />
                                    </LinearLayout>
                                </LinearLayout>

                                <!-- Personal CAGR section -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:background="@drawable/bg_cagr_section"
                                    android:padding="16dp"
                                    android:layout_marginTop="12dp">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="PERSONAL CAGR (1Y)"
                                            android:textSize="9sp"
                                            android:textStyle="bold"
                                            android:letterSpacing="0.08"
                                            android:textColor="@color/teal_800" />

                                        <TextView
                                            android:id="@+id/tvPersonalCagr"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="—%"
                                            android:textSize="22sp"
                                            android:textStyle="bold"
                                            android:textColor="@color/teal_800"
                                            android:layout_marginTop="2dp" />
                                    </LinearLayout>

                                    <ImageView
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:src="@drawable/ic_insights"
                                        android:tint="#6600695C"
                                        android:contentDescription="Insights" />
                                </LinearLayout>

                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- ── Expected Projections card (collapsible) ──────── -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardProjections"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white">

                        <LinearLayout
                            android:id="@+id/cardProjectionsInner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Header row -->
                            <LinearLayout
                                android:id="@+id/headerProjections"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:padding="20dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?attr/selectableItemBackground">

                                <FrameLayout
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/bg_section_icon"
                                    android:layout_marginEnd="12dp">
                                    <ImageView
                                        android:layout_width="22dp"
                                        android:layout_height="22dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_trending_up"
                                        android:tint="@color/teal_800"
                                        android:contentDescription="Projections" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Expected Projection"
                                    android:textColor="@color/text_dark"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                                <ImageView
                                    android:id="@+id/ivExpandProjections"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:src="@drawable/ic_expand_more"
                                    android:tint="@color/text_muted"
                                    android:contentDescription="Expand" />
                            </LinearLayout>

                            <!-- Projection rows (toggled) -->
                            <LinearLayout
                                android:id="@+id/contentProjections"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:paddingStart="20dp"
                                android:paddingEnd="20dp"
                                android:paddingBottom="20dp"
                                android:visibility="gone">

                                <!-- 1Y row -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:background="@drawable/bg_projection_row"
                                    android:padding="14dp">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="1Y FORECAST"
                                            android:textSize="9sp"
                                            android:textStyle="bold"
                                            android:letterSpacing="0.08"
                                            android:textColor="@color/text_muted" />

                                        <TextView
                                            android:id="@+id/tvProjected1y"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:textSize="15sp"
                                            android:textStyle="bold"
                                            android:textColor="@color/text_dark"
                                            android:layout_marginTop="2dp"
                                            android:text="₹0" />

                                        <TextView
                                            android:id="@+id/tvCagr1yPct"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:textSize="10sp"
                                            android:textStyle="bold"
                                            android:textColor="@color/amount_positive"
                                            android:text="+0.0%" />
                                    </LinearLayout>

                                    <com.example.personalwealthmanager.presentation.stocks.SparklineView
                                        android:id="@+id/sparkline1y"
                                        android:layout_width="90dp"
                                        android:layout_height="44dp" />
                                </LinearLayout>

                                <!-- 3Y row -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:background="@drawable/bg_projection_row"
                                    android:padding="14dp"
                                    android:layout_marginTop="10dp">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="3Y FORECAST"
                                            android:textSize="9sp"
                                            android:textStyle="bold"
                                            android:letterSpacing="0.08"
                                            android:textColor="@color/text_muted" />

                                        <TextView
                                            android:id="@+id/tvProjected3y"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:textSize="15sp"
                                            android:textStyle="bold"
                                            android:textColor="@color/text_dark"
                                            android:layout_marginTop="2dp"
                                            android:text="₹0" />

                                        <TextView
                                            android:id="@+id/tvCagr3yPct"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:textSize="10sp"
                                            android:textStyle="bold"
                                            android:textColor="@color/amount_positive"
                                            android:text="+0.0%" />
                                    </LinearLayout>

                                    <com.example.personalwealthmanager.presentation.stocks.SparklineView
                                        android:id="@+id/sparkline3y"
                                        android:layout_width="90dp"
                                        android:layout_height="44dp" />
                                </LinearLayout>

                                <!-- 5Y row -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:background="@drawable/bg_projection_row"
                                    android:padding="14dp"
                                    android:layout_marginTop="10dp">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="5Y FORECAST"
                                            android:textSize="9sp"
                                            android:textStyle="bold"
                                            android:letterSpacing="0.08"
                                            android:textColor="@color/text_muted" />

                                        <TextView
                                            android:id="@+id/tvProjected5y"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:textSize="15sp"
                                            android:textStyle="bold"
                                            android:textColor="@color/text_dark"
                                            android:layout_marginTop="2dp"
                                            android:text="₹0" />

                                        <TextView
                                            android:id="@+id/tvCagr5yPct"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:textSize="10sp"
                                            android:textStyle="bold"
                                            android:textColor="@color/amount_positive"
                                            android:text="+0.0%" />
                                    </LinearLayout>

                                    <com.example.personalwealthmanager.presentation.stocks.SparklineView
                                        android:id="@+id/sparkline5y"
                                        android:layout_width="90dp"
                                        android:layout_height="44dp" />
                                </LinearLayout>

                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- ── Holdings card ─────────────────────────────────── -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardHoldings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="8dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Holdings header -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="20dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="18dp"
                                android:paddingBottom="14dp">

                                <FrameLayout
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/bg_section_icon"
                                    android:layout_marginEnd="12dp">
                                    <ImageView
                                        android:layout_width="22dp"
                                        android:layout_height="22dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_asset_stocks"
                                        android:tint="@color/teal_800"
                                        android:contentDescription="Holdings" />
                                </FrameLayout>

                                <TextView
                                    android:id="@+id/tvHoldingsTitle"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Holdings"
                                    android:textColor="@color/text_dark"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                                <ImageButton
                                    android:id="@+id/btnFilter"
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:src="@drawable/ic_filter"
                                    android:tint="@color/text_muted"
                                    android:background="@drawable/bg_section_gray"
                                    android:padding="6dp"
                                    android:contentDescription="Filter" />
                            </LinearLayout>

                            <!-- Thin divider -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#0F000000" />

                            <!-- Holdings list (nested scroll disabled — outer NestedScrollView handles it) -->
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvHoldings"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:nestedScrollingEnabled="false"
                                android:overScrollMode="never" />

                            <!-- Empty state -->
                            <TextView
                                android:id="@+id/tvEmptyState"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/no_holdings"
                                android:textColor="@color/text_muted"
                                android:textSize="14sp"
                                android:gravity="center"
                                android:padding="32dp"
                                android:visibility="gone" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Loading overlay -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- Bottom nav pinned to bottom -->
        <include
            layout="@layout/layout_bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom" />

    </FrameLayout>

    <!-- ── Navigation Drawer ──────────────────────────────────────────── -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/drawer_bg"
        app:headerLayout="@layout/drawer_header" />

</androidx.drawerlayout.widget.DrawerLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/tx_bg"
    android:fitsSystemWindows="true">

    <!-- Top App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/tx_bg">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back_arrow"
            android:contentDescription="Back"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/tx_primary" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Edit Transaction"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/tx_primary"
            android:gravity="center" />

        <ImageView
            android:id="@+id/btnDeleteTop"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_edit_tx_delete"
            android:contentDescription="Delete transaction"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/tx_divider" />

    <!-- Content area: loader + scrollable form overlapping -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/tx_primary"
            android:visibility="visible" />

        <!-- Scrollable form -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/contentCard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="32dp">

                <!-- Fetch from Inbox Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnFetchFromInbox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <!-- Mail icon circle -->
                        <LinearLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_edit_tx_inbox_icon">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_edit_tx_mail"
                                android:contentDescription="@null" />
                        </LinearLayout>

                        <!-- Title + subtitle -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fetch from Inbox"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/tx_text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Find digital receipts automatically"
                                android:textSize="12sp"
                                android:textColor="@color/tx_text_secondary"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Scan pill button -->
                        <com.google.android.material.button.MaterialButton
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Scan"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/white"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:clickable="false"
                            android:focusable="false"
                            app:backgroundTint="@color/teal_800"
                            app:cornerRadius="20dp"
                            app:elevation="0dp"
                            app:strokeWidth="0dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- OR Divider -->
                <LinearLayout
                    android:id="@+id/orDivider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="4dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/tx_divider" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OR"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/tx_text_muted"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:letterSpacing="0.12" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/tx_divider" />

                </LinearLayout>

                <!-- Transaction Type label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transaction Type"
                    android:textSize="13sp"
                    android:textColor="@color/tx_text_secondary"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp" />

                <!-- Pill toggle: Expense | Income -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_filter_pill"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/btnToggleExpense"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Expense"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@null"
                        android:textColor="@color/tx_text_secondary"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/btnToggleIncome"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Income"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@null"
                        android:textColor="@color/tx_text_secondary"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- Amount section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="24dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AMOUNT"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/tx_text_muted"
                        android:letterSpacing="0.12" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/tx_text_secondary"
                            android:paddingEnd="4dp" />

                        <EditText
                            android:id="@+id/etAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textSize="48sp"
                            android:textStyle="bold"
                            android:textColor="@color/tx_text_primary"
                            android:background="@null"
                            android:gravity="center"
                            android:minWidth="80dp"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp"
                            android:hint="0.00"
                            android:textColorHint="@color/tx_text_muted" />
                    </LinearLayout>
                </LinearLayout>

                <!-- CATEGORY -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CATEGORY"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/tx_text_muted"
                    android:letterSpacing="0.12"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_edit_tx_field">

                    <AutoCompleteTextView
                        android:id="@+id/actvCategory"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="16dp"
                        android:paddingEnd="44dp"
                        android:gravity="center_vertical"
                        android:background="@null"
                        android:textColor="@color/tx_text_primary"
                        android:textColorHint="@color/tx_text_muted"
                        android:textSize="15sp"
                        android:completionThreshold="0"
                        android:dropDownHeight="200dp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="14dp"
                        android:src="@drawable/ic_filter_chevron"
                        android:contentDescription="@null" />
                </FrameLayout>

                <!-- RECIPIENT / SOURCE -->
                <TextView
                    android:id="@+id/tvSourceRecipientLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RECIPIENT"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/tx_text_muted"
                    android:letterSpacing="0.12"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_edit_tx_field">

                    <AutoCompleteTextView
                        android:id="@+id/actvSourceRecipient"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="16dp"
                        android:paddingEnd="44dp"
                        android:gravity="center_vertical"
                        android:background="@null"
                        android:textColor="@color/tx_text_primary"
                        android:textColorHint="@color/tx_text_muted"
                        android:textSize="15sp"
                        android:completionThreshold="0"
                        android:dropDownHeight="200dp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="14dp"
                        android:src="@drawable/ic_filter_person"
                        android:contentDescription="@null" />
                </FrameLayout>

                <!-- DATE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/tx_text_muted"
                    android:letterSpacing="0.12"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:id="@+id/datePickerLayout"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_edit_tx_field"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tvSelectedDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Select Date"
                        android:textSize="15sp"
                        android:textColor="@color/tx_text_primary" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_filter_calendar"
                        android:contentDescription="@null" />
                </LinearLayout>

                <!-- TIME -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIME"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/tx_text_muted"
                    android:letterSpacing="0.12"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:id="@+id/timePickerLayout"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_edit_tx_field"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tvSelectedTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Select Time"
                        android:textSize="15sp"
                        android:textColor="@color/tx_text_primary" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_edit_tx_clock"
                        android:contentDescription="@null" />
                </LinearLayout>

                <!-- PAYMENT METHOD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAYMENT METHOD"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/tx_text_muted"
                    android:letterSpacing="0.12"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_edit_tx_field">

                    <AutoCompleteTextView
                        android:id="@+id/actvPaymentMethod"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="16dp"
                        android:paddingEnd="44dp"
                        android:gravity="center_vertical"
                        android:background="@null"
                        android:textColor="@color/tx_text_primary"
                        android:textColorHint="@color/tx_text_muted"
                        android:textSize="15sp"
                        android:completionThreshold="0"
                        android:dropDownHeight="200dp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="14dp"
                        android:src="@drawable/ic_filter_payments"
                        android:contentDescription="@null" />
                </FrameLayout>

                <!-- TRANSACTION REFERENCE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRANSACTION REFERENCE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/tx_text_muted"
                    android:letterSpacing="0.12"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_edit_tx_field">

                    <EditText
                        android:id="@+id/etTransactionReference"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:gravity="center_vertical"
                        android:background="@null"
                        android:hint="e.g., TXN123456, Cheque #789"
                        android:inputType="text"
                        android:textColor="@color/tx_text_primary"
                        android:textColorHint="@color/tx_text_muted"
                        android:textSize="15sp" />
                </FrameLayout>

                <!-- TAGS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TAGS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/tx_text_muted"
                    android:letterSpacing="0.12"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_edit_tx_field">

                    <EditText
                        android:id="@+id/etTags"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:gravity="center_vertical"
                        android:background="@null"
                        android:hint="e.g., recurring, urgent, work"
                        android:inputType="text"
                        android:textColor="@color/tx_text_primary"
                        android:textColorHint="@color/tx_text_muted"
                        android:textSize="15sp" />
                </FrameLayout>

                <!-- NOTES -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOTES"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/tx_text_muted"
                    android:letterSpacing="0.12"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_tx_field">

                    <EditText
                        android:id="@+id/etNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:gravity="top|start"
                        android:background="@null"
                        android:hint="Add a memo about this transaction..."
                        android:inputType="textMultiLine"
                        android:minLines="3"
                        android:textColor="@color/tx_text_primary"
                        android:textColorHint="@color/tx_text_muted"
                        android:textSize="15sp" />
                </FrameLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

                <!-- Save Transaction -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpdate"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Save Transaction"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@color/teal_800"
                    app:cornerRadius="28dp"
                    app:icon="@drawable/ic_edit_tx_save"
                    app:iconGravity="textStart"
                    app:iconTint="@android:color/white"
                    app:elevation="0dp" />

                <!-- Delete Transaction link -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDelete"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp"
                    android:text="Delete Transaction"
                    android:textSize="14sp"
                    android:textColor="@color/drawer_logout_red"
                    app:icon="@drawable/ic_edit_tx_delete"
                    app:iconGravity="textStart"
                    app:iconTint="@color/drawer_logout_red"
                    app:rippleColor="@color/drawer_logout_red"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude auth prefs — session token must not be restored on another device -->
        <exclude domain="sharedpref" path="AppPrefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Exclude auth prefs from device-to-device transfer -->
        <exclude domain="sharedpref" path="AppPrefs.xml"/>
    </device-transfer>
</data-extraction-rules>
